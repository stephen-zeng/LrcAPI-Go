# LrcAPI-Go 配置模板
# 复制为 .env 后按需填写。二进制直接运行时会自动读取同目录下的 .env；
# 使用 docker-compose 时这些变量会通过 environment 注入容器。
# 所有凭据均为「可选」：留空则对应平台以匿名方式访问（部分平台匿名下可能拿不到歌词）。

# ---------- 基础 ----------
# 服务端口（等价于 --port）
LRCAPI_PORT=2233
# 访问密码 / Authorization 头（等价于 --pwd）。推荐用 LRCAPI_PWD，避免与 shell 的 PWD 变量冲突。
LRCAPI_PWD=lrc200681

# ---------- 无需凭据即可工作的来源 ----------
# 网易云音乐：匿名可用。可填登录 Cookie（含 MUSIC_U）以提高命中率与解锁部分歌词。
NETEASE_COOKIE=
# QQ 音乐：匿名可用（QRC 逐词歌词）。可填登录 Cookie 提升稳定性。
QQ_COOKIE=
# 酷狗音乐：匿名可用（KRC 逐词歌词）。Cookie 主要用于下载，一般无需填写。
KUGOU_COOKIE=

# ---------- 需要凭据的来源（当前主流程未启用，预留给后续扩展） ----------
# Apple Music：Developer Token（Bearer JWT）与 media-user-token。
# 来源：登录 music.apple.com 后从其前端 JS/请求头中提取；media-user-token 需登录账号。
APPLE_DEVELOPER_TOKEN=
APPLE_MEDIA_USER_TOKEN=
# Spotify：sp_dc Cookie。来源：登录 open.spotify.com 后从浏览器 Cookie 中复制 sp_dc。
SPOTIFY_SP_DC=
# 汽水音乐（Soda）：Cookie。来源：登录 qishui.com / 客户端抓包。
SODA_COOKIE=
# 哔哩哔哩：登录 Cookie（含 SESSDATA）。来源：登录 bilibili.com 后从浏览器 Cookie 复制。字幕接口通常必须。
BILIBILI_COOKIE=
# YouTube Music：登录 Cookie（可选）。来源：登录 music.youtube.com 后从浏览器 Cookie 复制。
YOUTUBE_MUSIC_COOKIE=

# ---------- 模型信息（OpenAI 兼容接口，用于异步补齐翻译/罗马音） ----------
# 三项均填写后才会启用「自动补全」：检测到外语缺中文翻译、或日/韩语缺罗马音时，
# 后台调用模型补齐并写回数据库（对客户端无感，补全结果下次查询生效）。留空则关闭该功能。
# BASE_URL 不需要含任何 v1 字样等；程序会自动拼接 /chat/completions。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=